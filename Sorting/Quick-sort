#include <iostream>
using namespace std;

int partition(int arr[], int low, int high){
    int pivot = arr[low];
    int i = low;
    int j = high;

    while(i < j){
        // to find the element greater than pivot 
        while(arr[i] <= pivot && i < high){
            // if not go ahead
            i++;
        }
        // to find the element is lesser than pivot element
        while(arr[j] > pivot && j > low){
            // if not go back
            j--;
        }

        if(i < j){
            //if i did not passes j to only swap b/w iterators
            swap(arr[i], arr[j]);
        }
    }
    // if  j passed i then you got your perfect position of pivot
    // [25,20,15,35,80,50,90,45]
    swap(arr[low], arr[j]);
    return j;
}

void qs(int arr[], int low, int high){
    if(low < high){
        int pindex = partition(arr, low, high);
        //[25,20,15,]
        qs(arr, low, pindex - 1);
        // [80,50,90,45]
        
        qs(arr, pindex + 1, high);
    }
}

int main(){
    int arr[] = {35,50,15,25,80,20,90,45};
    int n = sizeof(arr)/sizeof(arr[0]);

    qs(arr, 0, n - 1);

    for(int i = 0; i < n; i++){
        cout << arr[i] << " ";
    }

    return 0;
}
