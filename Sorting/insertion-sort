#include <iostream>
using namespace std;
void insertionsort(int arr[],int n){
    for(int i=1;i<n;i++){
        int j=i;
        while(j>0&& arr[j-1]>arr[j]){
            swap(arr[j-1],arr[j]);
            j--;
        }
    }
}



int main(){
    int arr[] = {35,50,15,25,80,20,90,45};
    int n = sizeof(arr)/sizeof(arr[0]);

    insertionsort(arr, n);

    for(int i = 0; i < n; i++){
        cout << arr[i] << " ";
    }

    return 0;
}
