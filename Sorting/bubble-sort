#include <iostream>
using namespace std;

void bubblesort(int arr[], int n){
    for(int i = 0; i < n - 1; i++){
        int didswap = 0;

        for(int j = 0; j < n - i - 1; j++){
            if(arr[j] > arr[j + 1]){
                swap(arr[j], arr[j + 1]);
                didswap = 1;
            }
        }

        if(didswap == 0){
            break;  // already sorted
        }
    }
}

int main(){ 
    int arr[] = {35,50,15,25,80,20,90,45};
    int n = sizeof(arr)/sizeof(arr[0]);

    bubblesort(arr, n);

    for(int i = 0; i < n; i++){
        cout << arr[i] << " ";
    }

    return 0;
}
