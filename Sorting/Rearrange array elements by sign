#include <iostream>
#include <vector>

using namespace std;

vector<int> rearrangeArray(vector<int>& nums) {
    int n = nums.size();
    vector<int> store(n, 0);

    int positive_index = 0;
    int negative_index = 1;

    for(int i = 0; i < n; i++){
        if(nums[i] >= 0){
            store[positive_index] = nums[i];
            positive_index += 2;
        }
        else{
            store[negative_index] = nums[i];
            negative_index += 2;
        }
    }

    return store;
}

int main() {
    vector<int> nums = {3, 1, -2, -5, 2, -4};

    vector<int> result = rearrangeArray(nums);

    cout << "Rearranged array: ";
    for(int x : result){
        cout << x << " ";
    }

    return 0;
}
