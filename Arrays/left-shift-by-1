#include <iostream>
#include <vector>

using namespace std;

void  LeftShiftByone( vector<int>& nums){
    int n= nums.size();
    int temp=nums[0];
    for(int i=0;i<n;i++){
        if(i!=n-1){
            nums[i]=nums[i+1];
        }
        else{
            nums[i]=temp;
        }
    }
    
   
}

int main(){
    vector<int> v = {1,1,0,1,1,1,0,1,1};
   

    LeftShiftByone(v);
    for(int i=0;i<v.size();i++){
        cout<< v[i]<<" ";
    }
 

    return 0;
}

// tc =O(n)
// sc= O(1)
