#include <iostream>
#include <vector>
using namespace std;

vector<int> pascalTriangleII(int r) {
    vector<int> ans(r);
    ans[0] = 1;

    for(int i = 1; i < r; i++){
        ans[i] = ans[i-1] * (r - i);
        ans[i] = ans[i] / i;
    }

    return ans;
}

int main() {
    int r;
    cout << "Enter row number: ";
    cin >> r;

    vector<int> result = pascalTriangleII(r);

    cout << "Result: ";
    for(int x : result){
        cout << x << " ";
    }

    return 0;
}
