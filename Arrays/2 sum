#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        vector<pair<int,int>> v;

        // Step 1: Store value with original index
        for(int i = 0; i < nums.size(); i++){
            v.push_back({nums[i], i});
        }

        // Step 2: Sort based on values
        sort(v.begin(), v.end());

        // Step 3: Two pointer approach
        int i = 0;
        int j = v.size() - 1;

        while(i < j){
            int sum = v[i].first + v[j].first;

            if(sum > target){
                j--;
            }
            else if(sum < target){
                i++;
            }
            else {
                vector<int> ans = {v[i].second, v[j].second};
                sort(ans.begin(), ans.end()); // increasing order
                return ans;
            }
        }

        return {}; // no solution (though problem guarantees one)
    }
};

 tc=O(nlogn)
 sc=O(n)
