#include <iostream>
#include <vector>
using namespace std;

void sortZeroOneTwo(vector<int>& nums) {
    int n = nums.size();
    int low = 0, mid = 0, high = n - 1;

    // Invariants:
    // 0 to low-1      -> all 0s
    // low to mid-1    -> all 1s
    // mid to high     -> unsorted
    // high+1 to n-1   -> all 2s

    while (mid <= high) {
        if (nums[mid] == 0) {
            swap(nums[low], nums[mid]);
            low++;
            mid++;
        }
        else if (nums[mid] == 1) {
            mid++;
        }
        else { // nums[mid] == 2
            swap(nums[mid], nums[high]);
            high--;
            // do NOT increment mid
        }
    }
}

int main() {
    vector<int> nums = {2, 0, 1, 2, 1, 0};

    sortZeroOneTwo(nums);

    cout << "Sorted array: ";
    for (int x : nums) {
        cout << x << " ";
    }

    return 0;
}
