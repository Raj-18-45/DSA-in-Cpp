
#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

// LEFT ROTATION
void LeftShiftByk(vector<int>& nums, int k){
    int n = nums.size();
    k = k % n;

    // let nums = {1,2,3,4,5,6,7};

    // s->1 reverse only k
    // {3,2,1,4,5,6,7}
    reverse(nums.begin(), nums.begin() + k);

    // s->2 reverse remaining
    // {3,2,1,7,6,5,4}
    reverse(nums.begin() + k, nums.end());

    // s->3 reverse whole array
    // {4,5,6,7,1,2,3}
    reverse(nums.begin(), nums.end());
}


// RIGHT ROTATION
void RightShiftByk(vector<int>& nums, int k){
    int n = nums.size();
    k = k % n;

    // let nums = {1,2,3,4,5,6,7};

    // s->1 reverse all array
    // {7,6,5,4,3,2,1}
    reverse(nums.begin(), nums.end());

    // s->2 reverse k
    // {5,6,7,4,3,2,1}
    reverse(nums.begin(), nums.begin() + k);

    // s->3 reverse remaining
    // {5,6,7,1,2,3,4}
    reverse(nums.begin() + k, nums.end());
}


int main(){
    vector<int> v = {1,2,3,4,5,6,7};
    int k = 3;

    LeftShiftByk(v, k);
    cout << "Left shift by " << k << ": ";
    for(int i = 0; i < v.size(); i++){
        cout << v[i] << " ";
    }

    cout << endl;

    RightShiftByk(v, k);
    cout << "Right shift by " << k << ": ";
    for(int i = 0; i < v.size(); i++){
        cout << v[i] << " ";
    }

    return 0;
}
